{
  "grpc": {
    "max_receive_message_size_mb": 150,
    "max_send_message_size_mb": 150,
    "compression": {
      "level": "high"
    },
    "batch_streaming": {
      "enabled": true,
      "batch_size": 500
    },
    "thread_pool": {
      "max_threads": 8,
      "min_pollers": 1
    },
    "keepalive": {
      "time_s": 30,
      "timeout_s": 10,
      "permit_without_calls": true
    }
  }
}
